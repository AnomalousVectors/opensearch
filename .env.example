# ----------------------------
# Data Volumes
# ----------------------------

# Required: persistent data/logs/certs outside the repo root.
# Linux example:   DATA_VOLUME_ROOT=/mnt/docker/opensearch-data
# macOS example:   DATA_VOLUME_ROOT=/Users/you/opensearch-data
# Windows example: DATA_VOLUME_ROOT=d:\opensearch-data
DATA_VOLUME_ROOT=d:\opensearch-data

# ----------------------------
# OpenSearch Environment Vars
# ----------------------------

CLUSTER_NAME=opensearch-cluster
COMPOSE_PROJECT_NAME=opensearch

# Docker network alias for OpenSearch (used between containers).
# On the host, add a hosts entry for opensearch.url or use https://127.0.0.1:9200.
OPENSEARCH_PUBLISH_HOST=opensearch.url

# Heap sizing plus a 200 MB per-string JSON parse ceiling for large captured HTTP bodies.
# Raise opensearch.json.max_string_length further if Discover/API responses still hit StreamReadConstraints limits.
OPENSEARCH_JAVA_OPTS=-Xms4g -Xmx16g -Dopensearch.transport.cname_in_publish_address=true -Dopensearch.json.max_string_length=200000000

# ----------------------------
# Networking
# ----------------------------

OPENSEARCH_DIAGNOSTICS_PORT=9600

OPENSEARCH_BIND_ADDRESS=0.0.0.0
#OPENSEARCH_BIND_ADDRESS=127.0.0.1
OPENSEARCH_PORT=9200

OPENSEARCH_DASHBOARDS_BIND_ADDRESS=0.0.0.0
#OPENSEARCH_DASHBOARDS_BIND_ADDRESS=127.0.0.1
OPENSEARCH_DASHBOARDS_PORT=5601
